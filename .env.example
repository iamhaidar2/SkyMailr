# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Local DB: leave DATABASE_URL unset to use SQLite (db.sqlite3).
# Railway / production:
# DATABASE_URL=postgres://user:pass@host:5432/skymailr

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Outbound email provider: dummy | console | postal
EMAIL_PROVIDER=dummy
POSTAL_BASE_URL=
POSTAL_SERVER_API_KEY=
POSTAL_TIMEOUT=30
POSTAL_USE_TLS_VERIFY=true

# LLM (BrainList-compatible — same env names)
# LLM_PROVIDER=dummy | openai | deepseek | anthropic
LLM_PROVIDER=dummy
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
SKYMAILR_DEFAULT_LLM_MODEL=gpt-4o-mini

# API key hashing pepper (set in production)
API_KEY_PEPPER=

# CORS / CSRF for admin + API
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# Optional
SENTRY_DSN=
LOG_LEVEL=INFO
